{
  "name": "vakansiya-bot",
  "version": "0.1.0",
  "description": "Telegram bot that aggregates Azerbaijani job vacancies hourly and notifies users based on their fields.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "set-webhook": "tsx scripts/set-webhook.ts",
    "db:apply:local": "wrangler d1 execute vakansiya-bot --local --file=schema.sql",
    "db:apply:remote": "wrangler d1 execute vakansiya-bot --remote --file=schema.sql"
  },
  "dependencies": {
    "grammy": "^1.30.0",
    "node-html-parser": "^6.1.13"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240512.0",
    "tsx": "^4.22.3",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "wrangler": "^3.60.0"
  },
  "engines": {
    "node": ">=20"
  }
}
